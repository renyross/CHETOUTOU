<div class="product-recommendations" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4">
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <section class="recommendations-section" style="padding: 5rem 0; background-color: #fff; overflow: hidden;">
      <div class="container" style="max-width: 1500px; margin: 0 auto; position: relative;">
        <h2 style="font-family:'Playfair Display', serif; font-size: 2rem; font-weight: 800; color: #111; margin-bottom: 3rem;">{{ section.settings.title }}</h2>
        
        <div class="recommendations-grid">
          {%- for recommendation in recommendations.products -%}
            <div class="rec-card">
              <a href="{{ recommendation.url }}" class="rec-link" style="text-decoration: none; color: inherit; display: block;">
                <div class="rec-img-box" style="aspect-ratio: 1/1; background: #f9f9f9; border-radius: 8px; overflow: hidden; margin-bottom: 1rem;">
                  {%- if recommendation.featured_image != blank -%}
                    <img src="{{ recommendation.featured_image | image_url: width: 500 }}" alt="{{ recommendation.title | escape }}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease;">
                  {%- else -%}
                    <div style="background:#eee; width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#aaa;">Produit</div>
                  {%- endif -%}
                </div>
                <h3 style="font-size: 0.9rem; font-weight: 600; color: #111; margin-bottom: 0.4rem; text-align: center;">{{ recommendation.title }}</h3>
                <div class="rec-price" style="font-size: 0.85rem; font-weight: 600; color: #666; text-align: center;">{{ recommendation.price | money }}</div>
              </a>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const handleIntersection = (entries, observer) => {
      if (!entries[0].isIntersecting) return;
      observer.unobserve(productRecommendationsSection);

      const url = productRecommendationsSection.dataset.url;

      fetch(url)
        .then(response => response.text())
        .then(html => {
          const div = document.createElement('div');
          div.innerHTML = html;
          const recommendations = div.querySelector('.product-recommendations');

          if (recommendations && recommendations.innerHTML.trim().length > 0) {
            productRecommendationsSection.innerHTML = recommendations.innerHTML;
          }
        })
        .catch(e => {
          console.error(e);
        });
    };

    const productRecommendationsSection = document.querySelector('.product-recommendations');
    if (!productRecommendationsSection) return;

    const observer = new IntersectionObserver(handleIntersection, {rootMargin: '0px 0px 200px 0px'});
    observer.observe(productRecommendationsSection);
  });
</script>

{% schema %}
{
  "name": "Produits Recommandés",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre de la Section",
      "default": "Vous aimerez aussi"
    }
  ],
  "presets": [
    {
      "name": "Produits Recommandés"
    }
  ]
}
{% endschema %}
