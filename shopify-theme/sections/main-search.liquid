<section class="collection-section" style="padding: 4rem 0;">
  <div class="container" style="max-width: 1500px; margin: 0 auto;">
    <h1 style="font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; color: #111; margin-bottom: 2rem; text-align: center;">
      {%- if search.performed -%}
        Résultats de recherche pour "{{ search.terms }}"
      {%- else -%}
        Recherche
      {%- endif -%}
    </h1>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="collection-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; margin-top: 3rem;">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <div class="product-item" data-product-id="{{ item.id }}">
                <a class="product-link-wrapper" href="{{ item.url }}" style="text-decoration: none; color: inherit; display: block;">
                  <div class="product-img-wrapper" style="aspect-ratio: 1/1; overflow: hidden; background: #f9f9f9; border-radius: 8px; margin-bottom: 1rem; position: relative;">
                    {%- if item.featured_image != blank -%}
                      <img src="{{ item.featured_image | image_url: width: 500 }}" alt="{{ item.title | escape }}" style="width: 100%; height: 100%; object-fit: cover;">
                    {%- else -%}
                      <div style="background: #eee; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #aaa;">Aucune image</div>
                    {%- endif -%}
                  </div>
                  <div class="product-info" style="text-align: center;">
                    <h3 style="font-size: 0.95rem; font-weight: 600; color: #111; margin-bottom: 0.5rem; line-height: 1.4;">
                      {{ item.title }}
                    </h3>
                    <p class="product-price" style="font-size: 0.9rem; font-weight: 700; color: #666;">
                      {{ item.price | money }}
                    </p>
                  </div>
                </a>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="text-align: center; color: #666; font-size: 1.1rem; margin-top: 3rem;">
          Votre recherche pour "{{ search.terms }}" n'a donné aucun résultat.
        </p>
      {%- endif -%}
    {%- else -%}
      <!-- Search input form if no search was performed -->
      <div style="max-width: 600px; margin: 3rem auto; text-align: center;">
        <form action="{{ routes.search_url }}" method="get" role="search" style="display: flex; gap: 10px;">
          <input type="search" name="q" placeholder="Rechercher un produit..." style="flex: 1; padding: 12px 20px; border: 1px solid #ddd; border-radius: 30px; outline: none; font-family: inherit; font-size: 1rem;">
          <button type="submit" style="background: #e69c1a; color: #fff; border: none; padding: 12px 30px; border-radius: 30px; font-weight: 600; cursor: pointer;">Rechercher</button>
        </form>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Résultats de Recherche",
  "settings": []
}
{% endschema %}
