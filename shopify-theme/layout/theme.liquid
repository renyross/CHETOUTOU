<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
        <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
        {{ page_title }}
        {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
        {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
        {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
        <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

    <!-- Global CSS -->
    {{ 'styles.css' | asset_url | stylesheet_tag }}

    <!-- Shopify Core Scripts -->
    {{ content_for_header }}

    <style>
        .logo {
            display: inline-block !important;
            text-align: center !important;
            line-height: 1.05 !important;
            vertical-align: middle !important;
        }
        .logo-sub {
            font-size: 0.45rem !important;
            font-weight: 500 !important;
            text-transform: none !important;
            letter-spacing: 0.02em !important;
            color: #666 !important;
            margin-top: 4px !important;
            display: block !important;
            white-space: nowrap !important;
        }
        .gallery-arrow {
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, transform 0.2s ease, visibility 0.3s;
        }
        .main-img-box:hover .gallery-arrow {
            opacity: 1;
            visibility: visible;
        }
        .main-product-img {
            cursor: default;
        }
    </style>
</head>
<body class="template-{{ template.name }} shop-page">
    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main role="main" id="MainContent" class="content-for-layout focus-none" tabindex="-1">
        {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <!-- Search Overlay -->
    <div class="search-overlay" id="search-overlay">
        <button aria-label="Fermer la recherche" class="close-search" id="close-search">
            <svg fill="none" height="30" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="30">
                <line x1="18" x2="6" y1="6" y2="18"></line>
                <line x1="6" x2="18" y1="6" y2="18"></line>
            </svg>
        </button>
        <div class="search-container">
            <form action="{{ routes.search_url }}" method="get" role="search" class="search-bar-glass">
                <div class="search-icon-inside">
                    <svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="24">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.3-4.3"></path>
                    </svg>
                </div>
                <input autocomplete="off" id="search-input" name="q" placeholder="Recherche..." type="search" value="{{ search.terms | escape }}" />
            </form>
        </div>
    </div>

    <!-- Cart Drawer -->
    <div class="cart-drawer" id="cart-drawer">
        <div class="cart-header">
            <h3>Panier</h3>
            <button aria-label="Fermer le panier" class="close-cart-btn" id="close-cart">
                <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24">
                    <line x1="18" x2="6" y1="6" y2="18"></line>
                    <line x1="6" x2="18" y1="6" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="cart-body">
            <!-- Items list (Dynamic) -->
            <div class="cart-items-container">
                <!-- JS will inject items here -->
            </div>
            <!-- Empty state -->
            <div class="cart-empty-state" style="padding-top: 20px;">
                <div class="empty-icon">
                    <svg fill="none" height="60" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" width="60">
                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                        <path d="M3 6h18"></path>
                        <path d="M16 10a4 4 0 0 1-8 0"></path>
                    </svg>
                </div>
                <h4>Votre panier est vide</h4>
                <p>Découvrez nos collections pour gâter votre compagnon.</p>
            </div>
            <!-- Promo Code -->
            <div class="cart-promo-v3">
                <input placeholder="Code de réduction" type="text" />
                <button class="btn-promo-apply">Appliquer</button>
            </div>
        </div>
        <!-- Footer Section -->
        <div class="cart-footer-v3">
            <div class="cart-total-row">
                <span class="total-label">Total estimé</span>
                <span id="cart-total-amount">0,00 €</span>
            </div>
            <a class="btn-checkout-v3" href="/checkout" style="text-decoration: none; display: block; text-align: center; line-height: 1;">
                Commander
            </a>
            <div class="cart-trust-badges">
                <img alt="Visa" src="https://img.icons8.com/color/48/visa.png" />
                <img alt="Mastercard" src="https://img.icons8.com/color/48/mastercard.png" />
                <img alt="Maestro" src="https://img.icons8.com/color/48/maestro.png" />
                <img alt="Apple Pay" src="https://img.icons8.com/color/48/apple-pay.png" />
                <img alt="Google Pay" src="https://img.icons8.com/color/48/google-pay.png" />
                <img alt="PayPal" src="https://img.icons8.com/color/48/paypal.png" />
            </div>
        </div>
    </div>
    <div class="cart-overlay" id="cart-overlay"></div>

    <!-- Global Scripts -->
    <script src="{{ 'main.js' | asset_url }}" defer="defer"></script>
</body>
</html>
